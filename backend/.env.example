# NVIDIA NIM API Key - get from https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# NIM model endpoints
NIM_MODEL=nvidia/nemotron-3-super-120b-a12b
NIM_EMBED_MODEL=nvidia/nv-embedqa-mistral-v1

# Demo mode (uses simulated agent outputs when no API key)
DEMO_MODE=false
USE_NVIDIA=true

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
